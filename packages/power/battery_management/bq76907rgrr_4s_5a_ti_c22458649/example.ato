"""Example usage of the bq76907rgrr_4s_5a_ti_c22458649 package."""

from "bq76907rgrr_4s_5a_ti_c22458649.ato" import BQ76907BatteryManagement4S

module Example:
    bms = new BQ76907BatteryManagement4S

    assert bms.battery.voltage within 12V to 16.8V
    assert bms.battery.max_current <= 5A
    assert bms.pack.max_current <= 5A
    assert bms.regout.voltage within 3.3V +/- 5%
    assert bms.regout.max_current <= 10mA
