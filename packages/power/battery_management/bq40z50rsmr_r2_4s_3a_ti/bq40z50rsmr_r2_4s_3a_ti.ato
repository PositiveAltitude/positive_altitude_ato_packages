"""BQ40Z50RSMR-R2 4S protected smart-battery frontend package."""

import ElectricLogic
import ElectricPower
import I2C
from "parts/Murata_Electronics_GRM155R71E104KE14D/Murata_Electronics_GRM155R71E104KE14D.ato" import Murata_Electronics_GRM155R71E104KE14D_package
from "parts/Murata_Electronics_GRM155R71H104KE14D/Murata_Electronics_GRM155R71H104KE14D.ato" import Murata_Electronics_GRM155R71H104KE14D_package
from "parts/Murata_Electronics_GRM188R61E225KA12D/Murata_Electronics_GRM188R61E225KA12D.ato" import Murata_Electronics_GRM188R61E225KA12D_package
from "parts/YAGEO_PA1206FRF470R001L/YAGEO_PA1206FRF470R001L.ato" import YAGEO_PA1206FRF470R001L_package
from "parts/YAGEO_RC0402FR_07100KL/YAGEO_RC0402FR_07100KL.ato" import YAGEO_RC0402FR_07100KL_package
from "parts/YAGEO_RC0402FR_07100RL/YAGEO_RC0402FR_07100RL.ato" import YAGEO_RC0402FR_07100RL_package
from "parts/YAGEO_RC0402FR_0710KL/YAGEO_RC0402FR_0710KL.ato" import YAGEO_RC0402FR_0710KL_package
from "parts/Texas_Instruments_BQ40Z50RSMR_R2/Texas_Instruments_BQ40Z50RSMR_R2.ato" import Texas_Instruments_BQ40Z50RSMR_R2_package
from "parts/XNRUSEMI_XRS30V06D/XNRUSEMI_XRS30V06D.ato" import XNRUSEMI_XRS30V06D_package

module BQ40Z50RSMR_R2_4S_3A_TI:
    """
    4S protected smart-battery frontend built around TI's BQ40Z50-R2.

    This package intentionally exposes only the protected pack interface:
    PACK+/PACK-, SMBC/SMBD, and BTP_INT. Raw cell-stack nodes remain internal
    to preserve the smart-pack abstraction agreed in planning.

    The charge/discharge path follows a high-side back-to-back N-FET structure
    using the same XNRUSEMI dual MOSFET already used elsewhere in the repo.
    Cell balancing support is kept internal to the BQ40Z50-R2 architecture by
    wiring the cell taps and recommended VC input filters.

    No thermistors are included. Instead, each TS input is biased with a fixed
    10-kohm resistor to VSS so the hardware can operate without external NTCs.
    Chemistry, balancing behavior, temperature policy, and any permanent-fail
    masking still require appropriate BQ40Z50-R2 configuration in TI's data
    flash for the target pack.

    PCHG is intentionally left unimplemented in this minimal package revision.
    This keeps the package aligned with the user's narrow scope while making the
    omission explicit for downstream integrators.
    """

    pack = new ElectricPower
    i2c = new I2C
    btp_int = new ElectricLogic

    signal cell_0
    signal tap_1
    signal tap_2
    signal tap_3
    signal cell_4
    signal fet_common
    signal pack_filtered
    signal vcc_filtered
    signal srp_filtered
    signal srn_filtered

    assert pack.voltage within 10V to 16.8V
    assert pack.max_current <= 3A

    cell_0.override_net_name = "GND"
    tap_1.override_net_name = "CELL1"
    tap_2.override_net_name = "CELL2"
    tap_3.override_net_name = "CELL3"
    cell_4.override_net_name = "CELL4"
    fet_common.override_net_name = "FET_COMMON"
    vcc_filtered.override_net_name = "BAT_FILT"
    srp_filtered.override_net_name = "SRP_FILT"
    srn_filtered.override_net_name = "SRN_FILT"
    pack.hv.override_net_name = "PACK+"
    pack.lv.override_net_name = "PACK-"

    monitor = new Texas_Instruments_BQ40Z50RSMR_R2_package
    protection_fets = new XNRUSEMI_XRS30V06D_package
    # 1mΩ 1W 1206 current-sense resistor
    sense_resistor = new YAGEO_PA1206FRF470R001L_package
    # 100Ω 1% 0402 series resistor
    vcc_series_resistor = new YAGEO_RC0402FR_07100RL_package
    # 10kΩ 1% 0402 bias resistor
    pack_series_resistor = new YAGEO_RC0402FR_0710KL_package
    # 100Ω 1% 0402 series resistor
    charge_gate_resistor = new YAGEO_RC0402FR_07100RL_package
    # 100Ω 1% 0402 series resistor
    discharge_gate_resistor = new YAGEO_RC0402FR_07100RL_package
    # 100kΩ 1% 0402 pull resistor
    charge_gate_pulldown = new YAGEO_RC0402FR_07100KL_package
    # 100kΩ 1% 0402 pull resistor
    discharge_gate_pulldown = new YAGEO_RC0402FR_07100KL_package
    # 100Ω 1% 0402 series resistor
    srp_filter_resistor = new YAGEO_RC0402FR_07100RL_package
    # 100Ω 1% 0402 series resistor
    srn_filter_resistor = new YAGEO_RC0402FR_07100RL_package
    # 100Ω 1% 0402 series resistor
    vc1_filter_resistor = new YAGEO_RC0402FR_07100RL_package
    # 100Ω 1% 0402 series resistor
    vc2_filter_resistor = new YAGEO_RC0402FR_07100RL_package
    # 100Ω 1% 0402 series resistor
    vc3_filter_resistor = new YAGEO_RC0402FR_07100RL_package
    # 100Ω 1% 0402 series resistor
    vc4_filter_resistor = new YAGEO_RC0402FR_07100RL_package
    # 10kΩ 1% 0402 bias resistor
    ts1_bias = new YAGEO_RC0402FR_0710KL_package
    # 10kΩ 1% 0402 bias resistor
    ts2_bias = new YAGEO_RC0402FR_0710KL_package
    # 10kΩ 1% 0402 bias resistor
    ts3_bias = new YAGEO_RC0402FR_0710KL_package
    # 10kΩ 1% 0402 bias resistor
    ts4_bias = new YAGEO_RC0402FR_0710KL_package
    # 100kΩ 1% 0402 pull resistor
    display_pullup = new YAGEO_RC0402FR_07100KL_package
    # 2.2uF X5R 25V 0603 hold capacitor
    pbi_hold_cap = new Murata_Electronics_GRM188R61E225KA12D_package
    # 100nF X7R 50V 0402 bypass capacitor
    bat_bypass = new Murata_Electronics_GRM155R71H104KE14D_package
    # 100nF X7R 50V 0402 bypass capacitor
    vcc_bypass = new Murata_Electronics_GRM155R71H104KE14D_package
    # 100nF X7R 50V 0402 bypass capacitor
    pack_bypass = new Murata_Electronics_GRM155R71H104KE14D_package
    # 100nF X7R 50V 0402 bypass capacitor
    current_sense_filter = new Murata_Electronics_GRM155R71H104KE14D_package
    # 100nF X7R 25V 0402 cell filter capacitor
    vc1_filter_cap = new Murata_Electronics_GRM155R71E104KE14D_package
    # 100nF X7R 25V 0402 cell filter capacitor
    vc2_filter_cap = new Murata_Electronics_GRM155R71E104KE14D_package
    # 100nF X7R 25V 0402 cell filter capacitor
    vc3_filter_cap = new Murata_Electronics_GRM155R71E104KE14D_package
    # 100nF X7R 25V 0402 cell filter capacitor
    vc4_filter_cap = new Murata_Electronics_GRM155R71E104KE14D_package
    i2c.scl.reference ~ pack
    i2c.sda.reference ~ pack
    btp_int.reference ~ pack

    i2c.scl.line ~ monitor.SMBC
    i2c.sda.line ~ monitor.SMBD
    btp_int.line ~ monitor.BTP_INT

    cell_0 ~ monitor.VSS
    cell_0 ~ monitor.EP
    cell_4 ~ monitor.BAT
    cell_4 ~ protection_fets.S1

    monitor.VSS.override_net_name = "GND"
    monitor.BAT.override_net_name = "CELL4"
    monitor.VCC.override_net_name = "BAT_FILT"
    monitor.PACK.override_net_name = "PACK_FILT"
    monitor.PBI.override_net_name = "PBI_HOLD"
    monitor.TS1.override_net_name = "TS1_BIAS"
    monitor.TS2.override_net_name = "TS2_BIAS"
    monitor.TS3.override_net_name = "TS3_BIAS"
    monitor.TS4.override_net_name = "TS4_BIAS"
    monitor.VC1.override_net_name = "VC1_FILT"
    monitor.VC2.override_net_name = "VC2_FILT"
    monitor.VC3.override_net_name = "VC3_FILT"
    monitor.VC4.override_net_name = "VC4_FILT"
    monitor.SRP.override_net_name = "SRP_FILT"
    monitor.SRN.override_net_name = "SRN_FILT"
    protection_fets.G1.override_net_name = "DSG_GATE"
    protection_fets.G2.override_net_name = "CHG_GATE"
    protection_fets.S1.override_net_name = "CELL4"
    protection_fets.S2.override_net_name = "PACK+"
    protection_fets.D1.override_net_name = "FET_COMMON"
    protection_fets.D2.override_net_name = "FET_COMMON"

    cell_4 ~ vcc_series_resistor.1
    vcc_series_resistor.2 ~ vcc_filtered
    vcc_filtered ~ monitor.VCC
    vcc_filtered ~ vcc_bypass.1
    vcc_bypass.2 ~ cell_0
    cell_4 ~ bat_bypass.1
    bat_bypass.2 ~ cell_0

    pack.hv ~ pack_series_resistor.1
    pack_series_resistor.2 ~ pack_filtered
    pack_filtered ~ monitor.PACK
    pack_filtered ~ pack_bypass.1
    pack_bypass.2 ~ cell_0

    monitor.PBI ~ pbi_hold_cap.1
    pbi_hold_cap.2 ~ cell_0
    monitor.PTC ~ cell_0
    monitor.PTCEN ~ cell_0
    monitor.FUSE ~ cell_0
    monitor.nPRESh_or_SHUTDN ~ cell_0
    cell_4 ~ display_pullup.1
    display_pullup.2 ~ monitor.nDISP

    tap_1 ~ vc1_filter_resistor.1
    vc1_filter_resistor.2 ~ monitor.VC1
    monitor.VC1 ~ vc1_filter_cap.1
    vc1_filter_cap.2 ~ cell_0
    tap_2 ~ vc2_filter_resistor.1
    vc2_filter_resistor.2 ~ monitor.VC2
    monitor.VC2 ~ vc2_filter_cap.1
    vc2_filter_cap.2 ~ tap_1
    tap_3 ~ vc3_filter_resistor.1
    vc3_filter_resistor.2 ~ monitor.VC3
    monitor.VC3 ~ vc3_filter_cap.1
    vc3_filter_cap.2 ~ tap_2
    cell_4 ~ vc4_filter_resistor.1
    vc4_filter_resistor.2 ~ monitor.VC4
    monitor.VC4 ~ vc4_filter_cap.1
    vc4_filter_cap.2 ~ tap_3

    monitor.TS1 ~ ts1_bias.1
    ts1_bias.2 ~ cell_0
    monitor.TS2 ~ ts2_bias.1
    ts2_bias.2 ~ cell_0
    monitor.TS3 ~ ts3_bias.1
    ts3_bias.2 ~ cell_0
    monitor.TS4 ~ ts4_bias.1
    ts4_bias.2 ~ cell_0

    cell_0 ~ sense_resistor.1
    sense_resistor.2 ~ pack.lv
    pack.lv ~ srp_filter_resistor.1
    srp_filter_resistor.2 ~ srp_filtered
    cell_0 ~ srn_filter_resistor.1
    srn_filter_resistor.2 ~ srn_filtered
    srp_filtered ~ monitor.SRP
    srn_filtered ~ monitor.SRN
    srp_filtered ~ current_sense_filter.1
    current_sense_filter.2 ~ srn_filtered

    protection_fets.D1 ~ fet_common
    protection_fets.D2 ~ fet_common
    protection_fets.S2 ~ pack.hv

    monitor.DSG ~ discharge_gate_resistor.1
    discharge_gate_resistor.2 ~ protection_fets.G1
    monitor.CHG ~ charge_gate_resistor.1
    charge_gate_resistor.2 ~ protection_fets.G2
    protection_fets.G1 ~ discharge_gate_pulldown.1
    discharge_gate_pulldown.2 ~ protection_fets.S1
    protection_fets.G2 ~ charge_gate_pulldown.1
    charge_gate_pulldown.2 ~ protection_fets.S2


module BQ40Z50BatteryFrontend4S from BQ40Z50RSMR_R2_4S_3A_TI:
    pass
