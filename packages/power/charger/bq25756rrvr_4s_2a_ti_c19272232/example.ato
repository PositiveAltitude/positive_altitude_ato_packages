"""Example usage of the bq25756rrvr_4s_2a_ti_c19272232 charger package."""

from "bq25756rrvr_4s_2a_ti_c19272232.ato" import BQ25756Charger4S

module Example:
    charger = new BQ25756Charger4S

    assert charger.power_in.voltage within 12V to 20V
    assert charger.battery.voltage within 12V to 16.8V
    assert charger.battery.max_current <= 2A
    assert charger.logic_power.voltage within 3.3V +/- 5%
