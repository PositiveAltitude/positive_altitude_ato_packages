"""Example usage of the tps25730drefr_20v_3a_ti USB-PD sink controller package."""

from "tps25730drefr_20v_3a_ti.ato" import TPS25730AutonomousSinkController

module Example:
    sink = new TPS25730AutonomousSinkController

    assert sink.usb_vbus.voltage within 5V to 20V
    assert sink.sink_vbus.max_current <= 3A
    assert sink.logic_3v3.voltage within 3V to 3.6V
