    package = "0402"
    manufacturer = "Samsung Electro-Mechanics"
    mpn = "CL05B104KB54PNC"
    lcsc_id = "C307331"
    datasheet_url = "https://www.lcsc.com/datasheet/lcsc_datasheet_2304140030_Samsung-Electro-Mechanics-CL05B104KB54PNC_C307331.pdf"

