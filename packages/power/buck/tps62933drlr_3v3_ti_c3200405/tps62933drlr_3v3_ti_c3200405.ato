    inductance = 6.8uH +/- 20%
    max_current = 4.5A
    saturation_current = 8A
    dc_resistance = 60mohm
    package = "SMD7_3x6_6mm"
    manufacturer = "Chilisin Elec"
    mpn = "MHCI06030-6R8M-R8"
    lcsc_id = "C108296"
