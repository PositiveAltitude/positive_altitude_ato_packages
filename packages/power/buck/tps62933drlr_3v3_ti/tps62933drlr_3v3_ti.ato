"""TPS62933DRLR 3.3 V buck converter package pinned to TI C3200405."""

import ElectricPower
from "parts/Murata_Electronics_GRM155R71H104KE14D/Murata_Electronics_GRM155R71H104KE14D.ato" import Murata_Electronics_GRM155R71H104KE14D_package
from "parts/Murata_Electronics_GRM155R71H333KE14D/Murata_Electronics_GRM155R71H333KE14D.ato" import Murata_Electronics_GRM155R71H333KE14D_package
from "parts/Murata_Electronics_GRM31CR61E226KE15L/Murata_Electronics_GRM31CR61E226KE15L.ato" import Murata_Electronics_GRM31CR61E226KE15L_package
from "parts/Murata_Electronics_GRM31CR61H106KA12L/Murata_Electronics_GRM31CR61H106KA12L.ato" import Murata_Electronics_GRM31CR61H106KA12L_package
from "parts/YAGEO_RC0402FR_0710KL/YAGEO_RC0402FR_0710KL.ato" import YAGEO_RC0402FR_0710KL_package
from "parts/YAGEO_RC0402FR_0731K6L/YAGEO_RC0402FR_0731K6L.ato" import YAGEO_RC0402FR_0731K6L_package
from "parts/cjiang_FTC252012S2R2MBCA/cjiang_FTC252012S2R2MBCA.ato" import cjiang_FTC252012S2R2MBCA_package
from "parts/Texas_Instruments_TPS62933DRLR/Texas_Instruments_TPS62933DRLR.ato" import Texas_Instruments_TPS62933DRLR_package

module TPS62933DRLR_3V3_TI:
    """
    Fixed 3.3 V implementation of TPS62933DRLR using the TI reference design.

    RT is tied to GND to select the controller's fixed 1.2 MHz mode. The inductor
    is resized to a compact 2.2 uH part and the design is intentionally derated to
    1 A output current. With the selected FTC252012S2R2MBCA inductor, a practical
    continuous output current ceiling is about 2.5 A, with roughly 3 A as the hard
    upper edge before inductor and regulator limits converge. The 33 nF soft-start
    capacitor is required because the SS pin must not float.
    """

    power_in = new ElectricPower
    power_out = new ElectricPower

    assert power_in.voltage within 3.8V to 30V
    assert power_out.voltage within 3.3V +/- 2%
    assert power_out.max_current <= 1A

    converter = new Texas_Instruments_TPS62933DRLR_package
    input_bulk_a = new Murata_Electronics_GRM31CR61H106KA12L_package
    input_bulk_b = new Murata_Electronics_GRM31CR61H106KA12L_package
    input_bypass = new Murata_Electronics_GRM155R71H104KE14D_package
    output_bulk_a = new Murata_Electronics_GRM31CR61E226KE15L_package
    output_bulk_b = new Murata_Electronics_GRM31CR61E226KE15L_package
    bootstrap_cap = new Murata_Electronics_GRM155R71H104KE14D_package
    soft_start_cap = new Murata_Electronics_GRM155R71H333KE14D_package
    output_inductor = new cjiang_FTC252012S2R2MBCA_package
    feedback_top = new YAGEO_RC0402FR_0731K6L_package
    feedback_bottom = new YAGEO_RC0402FR_0710KL_package
    power_in.lv ~ power_out.lv

    power_in.hv ~ converter.VIN
    power_in.lv ~ converter.GND
    power_in.hv ~ converter.EN
    converter.RT ~ power_in.lv

    converter.SS ~ soft_start_cap.1
    soft_start_cap.2 ~ power_in.lv
    converter.BST ~ bootstrap_cap.1
    bootstrap_cap.2 ~ converter.SW
    converter.SW ~ output_inductor.1
    output_inductor.2 ~ power_out.hv
    power_out.hv ~ feedback_top.1
    feedback_top.2 ~ converter.FB
    converter.FB ~ feedback_bottom.1
    feedback_bottom.2 ~ power_out.lv

    power_in.hv ~ input_bulk_a.1
    input_bulk_a.2 ~ power_in.lv
    power_in.hv ~ input_bulk_b.1
    input_bulk_b.2 ~ power_in.lv
    power_in.hv ~ input_bypass.1
    input_bypass.2 ~ power_in.lv

    power_out.hv ~ output_bulk_a.1
    output_bulk_a.2 ~ power_out.lv
    power_out.hv ~ output_bulk_b.1
    output_bulk_b.2 ~ power_out.lv

module TPS62933Buck3V3 from TPS62933DRLR_3V3_TI:
    pass
